{
    "name": "kilossets",
    "version": "1.0.0",
    "description": "Asset 'pipeline' for Kilonova",
    "scripts": {
        "watchCSS": "echo 'WARNING: All fonts WILL break.' && tailwindcss --postcss postcss.config.cjs -i tailwind.css --watch -o ../static/styles.css",
        "buildCSS": "postcss vendor.css -o ../static/vendored.css && tailwindcss -i ./tailwind.css -o ../static/styles.css",
        "prodCSS": "NODE_ENV=production pnpm run buildCSS",
        "buildJS": "esbuild app.ts --bundle --target=es2022 --outfile=../static/bundle.js --global-name=bundled --sourcemap=inline ",
        "prodJS": "esbuild app.ts  --bundle --target=es2022 --outfile=../static/bundle.js --global-name=bundled --sourcemap --minify ",
        "vendor": "esbuild vendored.ts --bundle --target=es2022 --outfile=../static/vendored.js --global-name=vendored --sourcemap --minify",
        "prod": "pnpm run prodJS && pnpm run vendor && pnpm run prodCSS",
        "build": "pnpm run buildJS && pnpm run buildCSS",
        "esv": "esbuild --version"
    },
    "license": "",
    "private": true,
    "type": "module",
    "dependencies": {
        "@fontsource/noto-sans": "^5.2.10",
        "@fortawesome/fontawesome-free": "^6.7.2",
        "@sentry/browser": "^10.56.0",
        "@tailwindcss/cli": "^4.3.0",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/typography": "^0.5.19",
        "@types/alpinejs": "^3.13.11",
        "@types/codemirror": "^5.60.17",
        "@types/js-cookie": "^3.0.6",
        "@types/lodash-es": "^4.17.12",
        "@types/preact-custom-element": "^4.0.4",
        "@types/sprintf-js": "^1.1.4",
        "alpinejs": "^3.15.12",
        "autoprefixer": "^10.5.0",
        "codemirror": "^5.65.20",
        "cssnano": "^8.0.1",
        "dayjs": "^1.11.20",
        "esbuild": "^0.28.0",
        "highlightjs-copy": "^1.0.6",
        "htmx.org": "2.0.10",
        "idiomorph": "^0.7.4",
        "js-base64": "^3.7.8",
        "js-cookie": "^3.0.8",
        "katex": "0.17.0",
        "lit": "^3.3.3",
        "lodash-es": "^4.18.1",
        "notyf": "^3.10.0",
        "postcss": "^8.5.15",
        "postcss-cli": "^11.0.1",
        "postcss-import": "^16.1.1",
        "postcss-url": "^10.1.4",
        "preact": "^10.29.2",
        "preact-custom-element": "^4.6.0",
        "query-string": "^9.4.0",
        "sprintf-js": "^1.1.3",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3"
    }
}
